rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Catch-all Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "marketersinanvk@gmail.com"
      );
    }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'category', 'imageUrl']) &&
        data.title is string && data.title.size() <= 200 &&
        data.category in ["Web", "Graphics", "Video Editing"] &&
        data.imageUrl is string && data.imageUrl.size() <= 1000 &&
        (data.get('description', '') is string) &&
        (data.get('link', '') is string) &&
        (data.get('tags', []) is list);
    }

    function isValidBlogPost(data) {
      return data.keys().hasAll(['title', 'content', 'slug']) &&
        data.title is string && data.title.size() <= 300 &&
        data.content is string && data.content.size() <= 50000 &&
        data.slug is string && data.slug.size() <= 128 &&
        (data.get('excerpt', '') is string) &&
        (data.get('category', '') is string) &&
        (data.get('imageUrl', '') is string);
    }

    function isValidService(data) {
      return data.keys().hasAll(['title', 'description']) &&
        data.title is string && data.title.size() <= 200 &&
        data.description is string && data.description.size() <= 2000;
    }

    function isValidCMS(data) {
      return data.keys().hasAll(['page']) &&
        data.page is string && data.page.size() <= 100;
    }

    function isValidCertification(data) {
      return data.keys().hasAll(['title', 'issuer', 'imageUrl']) &&
        data.title is string && data.title.size() <= 300 &&
        data.issuer is string && data.issuer.size() <= 300 &&
        data.imageUrl is string && data.imageUrl.size() <= 1000;
    }

    // --- Collection Rules ---

    match /projects/{projectId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProject(incoming()) && isValidId(projectId);
      allow update: if isAdmin() && isValidProject(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'category', 'description', 'imageUrl', 'link', 'tags'])
      );
      allow delete: if isAdmin();
    }

    match /blog/{postId} {
      allow read: if true;
      allow create: if isAdmin() && isValidBlogPost(incoming()) && isValidId(postId);
      allow update: if isAdmin() && isValidBlogPost(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'slug', 'excerpt', 'category', 'imageUrl'])
      );
      allow delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create: if isAdmin() && isValidService(incoming()) && isValidId(serviceId);
      allow update: if isAdmin() && isValidService(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'keywords', 'icon'])
      );
      allow delete: if isAdmin();
    }

    match /cms/{contentId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCMS(incoming()) && isValidId(contentId);
      allow update: if isAdmin() && isValidCMS(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['h1', 'metaTitle', 'metaDesc', 'fullContent', 'page', 'updatedAt'])
      );
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(docId);
    }

    match /certification/{certId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCertification(incoming()) && isValidId(certId);
      allow update: if isAdmin() && isValidCertification(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'issuer', 'imageUrl', 'date', 'link', 'updatedAt'])
      );
      allow delete: if isAdmin();
    }

    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      // Bootstrapped admin is handled in isAdmin() helper by email
      allow write: if false; // Admins are managed via console or bootstrap
    }
  }
}
