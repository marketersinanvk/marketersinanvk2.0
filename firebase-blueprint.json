{
  "entities": {
    "project": {
      "title": "Portfolio Project",
      "description": "A creative project showcasing my expertise",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Project title" },
        "category": { "type": "string", "enum": ["Web", "Graphics", "Video Editing"] },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "link": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "category", "imageUrl"]
    },
    "blogPost": {
      "title": "Blog Post",
      "description": "An insight-rich article about digital marketing and AI",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "author": { "type": "string" },
        "date": { "type": "string" },
        "imageUrl": { "type": "string" },
        "slug": { "type": "string" }
      },
      "required": ["title", "content", "slug"]
    },
    "service": {
      "title": "Service Offering",
      "description": "A high-impact service for scaling brands",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "icon": { "type": "string" }
      },
      "required": ["title", "description"]
    },
    "seoContent": {
      "title": "SEO Configuration",
      "description": "Dynamic SEO text for page-level optimization",
      "type": "object",
      "properties": {
        "page": { "type": "string" },
        "h1": { "type": "string" },
        "metaTitle": { "type": "string" },
        "metaDesc": { "type": "string" },
        "fullContent": { "type": "string" }
      },
      "required": ["page"]
    },
    "certification": {
      "title": "Professional Certification",
      "description": "Verified credentials and industry certifications",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "issuer": { "type": "string" },
        "date": { "type": "string" },
        "imageUrl": { "type": "string" },
        "link": { "type": "string" }
      },
      "required": ["title", "issuer", "imageUrl"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "project",
      "description": "Showcase of filterable projects"
    },
    "/blog/{postId}": {
      "schema": "blogPost",
      "description": "Digital marketing and AI insights"
    },
    "/services/{serviceId}": {
      "schema": "service",
      "description": "Core business offerings"
    },
    "/certification/{certId}": {
      "schema": "certification",
      "description": "Professional credentials"
    },
    "/cms/{contentId}": {
      "schema": "seoContent",
      "description": "Dynamic text management for SEO overhaul"
    },
    "/settings/{docId}": {
      "schema": "globalSettings",
      "description": "Global website configurations and CMS metadata"
    }
  }
}
