// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: portfolio
// Fields:
//   - title: string (required)
//   - category: string (required)
//   - client: string (optional)
//   - image: string (required)
//   - description: string (optional)
//   - createdAt: timestamp (optional)
//
// Collection: services
// Fields:
//   - title: string (required)
//   - description: string (required)
//   - image: string (optional)
//   - order: number (optional)
//
// Collection: posts
// Fields:
//   - title: string (required)
//   - excerpt: string (optional)
//   - content: string (required)
//   - category: string (optional)
//   - author: string (optional)
//   - date: string (optional)
//   - image: string (required)
//   - tags: list (optional)
//   - seoAlt: string (optional)
//
// Collection: testimonials
// Fields:
//   - name: string (required)
//   - brand: string (optional)
//   - companyType: string (optional)
//   - review: string (required)
//   - glow: string (optional)
//
// Collection: users
// Fields:
//   - email: string (required)
//   - role: string (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "marketersinanvk@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // ===============================================================
    // Validation Functions
    // ===============================================================

    function isValidPortfolio(data) {
      return data.keys().hasAll(['title', 'category', 'image']) &&
             isValidString(data.title, 1, 100) &&
             isValidString(data.category, 1, 50) &&
             isValidUrl(data.image);
    }

    function isValidService(data) {
      return data.keys().hasAll(['title', 'description']) &&
             isValidString(data.title, 1, 100) &&
             isValidString(data.description, 1, 1000);
    }

    function isValidPost(data) {
      return data.keys().hasAll(['title', 'content', 'image']) &&
             isValidString(data.title, 1, 200) &&
             isValidString(data.content, 1, 50000) &&
             isValidUrl(data.image);
    }

    function isValidTestimonial(data) {
      return data.keys().hasAll(['name', 'review']) &&
             isValidString(data.name, 1, 100) &&
             isValidString(data.review, 1, 1000);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    match /portfolio/{projectId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidPortfolio(request.resource.data);
      allow delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidService(request.resource.data);
      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidPost(request.resource.data);
      allow delete: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidTestimonial(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
